# Sovra Environment Variables
# Copy this file to .env.local and fill in the required values.
# Never commit .env.local or any file containing real secrets.

# =============================================================================
# Supabase (required)
# Get these from: supabase status (local) or your Supabase project dashboard
# =============================================================================
NEXT_PUBLIC_SUPABASE_URL=http://localhost:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-from-supabase-status
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-from-supabase-status

# =============================================================================
# Database (required - direct connection for Go worker)
# =============================================================================
DATABASE_URL=postgresql://postgres:postgres@localhost:54322/postgres

# =============================================================================
# Go Worker
# =============================================================================
HTTP_PORT=8080
GRPC_PORT=50051
MCP_PORT=3001
SOCKETIO_PORT=3002
GO_ENV=development
AGENT_WORKSPACE_PATH=/tmp/agent-workspace
SOCKETIO_ALLOWED_ORIGINS=http://localhost:3000
INTERNAL_API_SECRET=generate-a-random-secret-here
SUPABASE_JWT_SECRET=your-supabase-jwt-secret

# =============================================================================
# AI Providers (at least one required for agent features)
# =============================================================================
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
HUGGINGFACE_API_KEY=
# Optional override for OpenAI-compatible Hugging Face endpoint.
HUGGINGFACE_BASE_URL=https://router.huggingface.co/v1
# Optional routing policy suffix for model names without an explicit suffix.
# Examples: fastest, cheapest, preferred, sambanova.
HUGGINGFACE_ROUTING_POLICY=fastest

# =============================================================================
# Worker Service URLs (web -> worker communication)
# =============================================================================
NEXT_PUBLIC_WORKER_URL=http://localhost:3002
NEXT_PUBLIC_WORKER_SOCKET_URL=http://localhost:3002
WORKER_MCP_URL=http://localhost:3001/mcp
# Optional private URL used by server-side broadcasts.
WORKER_INTERNAL_URL=http://localhost:3002
# Optional private URL for worker health probes from the web admin.
WORKER_HEALTH_URL=http://localhost:8080

# =============================================================================
# App
# =============================================================================
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# =============================================================================
# Billing - Stripe (optional)
# Leave empty to disable billing features. When absent, billing is a no-op.
# Create products and prices in your Stripe dashboard, then copy the IDs here.
# =============================================================================
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID_PRO=
STRIPE_PRICE_ID_ENTERPRISE=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# =============================================================================
# Rate Limiting - Upstash Redis (optional)
# Leave empty to disable API key rate limiting. When absent, all requests pass.
# Create a Redis database at https://console.upstash.com
# =============================================================================
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# =============================================================================
# Monitoring - Sentry (optional)
# Leave empty to disable error tracking. When absent, errors are console-only.
# Create a project at https://sentry.io and copy the DSN.
# =============================================================================
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# =============================================================================
# Analytics - PostHog (optional)
# Leave empty to disable product analytics. When absent, events are dropped.
# Create a project at https://posthog.com and copy the project API key.
# =============================================================================
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
POSTHOG_KEY=
POSTHOG_HOST=https://us.i.posthog.com

# =============================================================================
# Search (optional)
# =============================================================================
BRAVE_SEARCH_API_KEY=
