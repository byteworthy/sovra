{
  "name": "sovra",
  "version": "1.0.0",
  "private": true,
  "description": "Open-source platform for building multi-tenant AI agent applications with MCP, vector search, and real-time collaboration",
  "scripts": {
    "dev": "pnpm -r --parallel dev",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "test": "pnpm -r test",
    "type-check": "pnpm -r type-check",
    "go:build": "cd packages/worker && go build ./cmd/worker",
    "go:test": "cd packages/worker && go test ./...",
    "go:dev": "cd packages/worker && air -c .air.toml",
    "go:lint": "cd packages/worker && go vet ./...",
    "db:generate": "supabase gen types typescript --local > packages/shared/types/database.ts",
    "db:reset": "supabase db reset"
  },
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "keywords": [
    "ai-agents",
    "mcp",
    "model-context-protocol",
    "multi-tenant",
    "saas-boilerplate",
    "nextjs",
    "supabase",
    "vector-search",
    "pgvector",
    "ai-platform",
    "open-source",
    "self-hosted",
    "multi-agent",
    "golang",
    "stripe"
  ],
  "license": "MIT"
}
