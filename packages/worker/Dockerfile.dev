FROM golang:1.22-alpine@sha256:1699c10032ca2582ec89a24a1312d986a3f094aed3d5c1147b19880afe40e052

RUN go install github.com/air-verse/air@v1.65.0

WORKDIR /app

# Cache dependencies before copying source
COPY go.mod go.sum ./
RUN go mod download

COPY . .

EXPOSE 8080 50051

CMD ["air", "-c", ".air.toml"]
