# ByteSwarm Worker — Environment Variables
# Copy to .env and fill in your values

# Database (required)
DATABASE_URL=postgresql://postgres:postgres@localhost:54322/postgres

# Server Ports
HTTP_PORT=8080
GRPC_PORT=50051
MCP_PORT=3001
SOCKETIO_PORT=3002

# Security
SOCKETIO_ALLOWED_ORIGINS=http://localhost:3000
INTERNAL_API_SECRET=generate-a-random-secret-here
SUPABASE_JWT_SECRET=your-supabase-jwt-secret

# AI Providers (for MCP tool execution)
OPENAI_API_KEY=sk-...
BRAVE_SEARCH_API_KEY=BSA...

# Runtime
GO_ENV=development
AGENT_WORKSPACE_PATH=/tmp/agent-workspace
