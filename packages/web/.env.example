# Sovra — Environment Variables
# Copy to .env.local and fill in your values

# Supabase (required)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# AI Providers (at least one required for agent chat)
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
HUGGINGFACE_API_KEY=hf_...
HUGGINGFACE_BASE_URL=https://router.huggingface.co/v1
HUGGINGFACE_ROUTING_POLICY=fastest

# Stripe (optional — billing features)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID_PRO=price_...
STRIPE_PRICE_ID_ENTERPRISE=price_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# PostHog (optional — analytics)
NEXT_PUBLIC_POSTHOG_KEY=phc_...
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Sentry (optional — error tracking)
SENTRY_DSN=https://...@sentry.io/...
SENTRY_ORG=your-org
SENTRY_PROJECT=your-project
SENTRY_AUTH_TOKEN=sntrys_...

# Upstash Redis (optional — rate limiting)
UPSTASH_REDIS_REST_URL=https://...upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token

# API key hashing secret (required in production when using API keys)
API_KEY_HASH_SECRET=replace-with-32-plus-char-random-secret

# Internal API (worker <-> web shared secret)
INTERNAL_API_SECRET=generate-a-random-secret-here

# Go Worker
NEXT_PUBLIC_WORKER_URL=http://localhost:3002
NEXT_PUBLIC_WORKER_SOCKET_URL=http://localhost:3002
WORKER_MCP_URL=http://localhost:3001/mcp
# Optional server-side private URL for web -> worker internal broadcast calls.
# Use this in production to keep internal traffic off public ingress.
WORKER_INTERNAL_URL=http://localhost:3002
# Optional server-side private URL for worker health checks in admin.
WORKER_HEALTH_URL=http://localhost:8080

# App URL (used for OAuth redirects)
NEXT_PUBLIC_APP_URL=http://localhost:3000
